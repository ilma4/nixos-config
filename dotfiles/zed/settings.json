{
  "project_panel": {
    "dock": "left",
  },
  "git_panel": {
    "dock": "left",
  },
  "edit_predictions": {
    "mode": "eager",
  },
  "agent": {
    "sidebar_side": "right",
    "notify_when_agent_waiting": "all_screens",
    "default_profile": "write",
    "default_model": {
      "model": "claude-haiku-4.5",
      "provider": "copilot_chat",
    },
  },
  "auto_install_extensions": {
    "basher": true,
    "docker-compose": true,
    "dockerfile": true,
    "haskell": true,
    "html": true,
    "ini": true,
    "kotlin": true,
    "latex": true,
    "log": true,
    "markdown-oxide": true,
    "nix": true,
    "swift": true,
    "toml": true,
    "xml": true,
  },
  "auto_update": false,
  "autosave": "on_focus_change",
  "base_keymap": "JetBrains",
  "buffer_font_family": "JetBrains Mono",
  "buffer_font_features": {
    "calt": false,
  },
  "buffer_font_size": 13,
  "context_servers": {
    "mcp-nixos": {
      "command": "nix",
      "args": ["run", "github:utensils/mcp-nixos", "--"],
      "env": {},
    },
  },
  "languages": {
    "Nix": {
      "formatter": {
        "external": {
          "arguments": ["--quiet", "--"],
          "command": "alejandra",
        },
      },
    },
  },
  "lsp": {
    "nil": {
      "settings": {
        "diagnostics": {
          "ignored": ["unused_binding"],
        },
        "nix": {
          "flake": {
            "autoArchive": true,
          },
        },
      },
    },
    "nixd": {
      "settings": {
        "diagnostic": {
          "suppress": ["sema-extra-with"],
        },
      },
    },
  },
  "theme": {
    "dark": "One Dark",
    "light": "One Light",
    "mode": "system",
  },
  "ui_font_size": 14,
  "vim_mode": true,
}
