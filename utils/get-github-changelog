#!/usr/bin/env bash
set -euo pipefail

usage() {
    echo "Usage: get-github-changelog <github-owner/repo|github-url> <from-release> <to-release>" >&2
}

if [ "$#" -ne 3 ]; then
    usage
    exit 2
fi

script_dir=$(CDPATH='' cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
repo_root=$(CDPATH='' cd -- "$script_dir/.." && pwd)

exec "$repo_root/scripts/github-releases-since.py" "$1" "$2" --until-release "$3"
