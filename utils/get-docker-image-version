#!/usr/bin/env python3
"""Print a Docker image version variable from a Nix service file."""

from __future__ import annotations

import argparse
import json
import re
import sys
from pathlib import Path

ASSIGNMENT_PATTERN = re.compile(
    r"^(?P<indent>\s*)(?P<name>[A-Za-z_][A-Za-z0-9_-]*)\s*=\s*"
    r'"(?P<value>[^"\n]*)";(?P<trailing>[^\n]*)$',
    re.MULTILINE,
)


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="Get a version variable from a Nix docker-compose service file."
    )
    parser.add_argument("nix_file", type=Path)
    parser.add_argument(
        "version_name",
        nargs="?",
        help="Exact Nix variable name. Required when the file has multiple versions.",
    )
    parser.add_argument(
        "--field",
        choices=("value", "name", "json"),
        default="value",
        help="Field to print. Defaults to the version value.",
    )
    return parser.parse_args()


def version_assignments(text: str) -> list[re.Match[str]]:
    return [
        match
        for match in ASSIGNMENT_PATTERN.finditer(text)
        if "version" in match.group("name").lower()
    ]


def select_assignment(
    assignments: list[re.Match[str]], version_name: str | None
) -> re.Match[str]:
    if version_name is not None:
        matches = [
            match for match in assignments if match.group("name") == version_name
        ]
        if len(matches) == 1:
            return matches[0]
        if not matches:
            raise ValueError(f"Version variable {version_name!r} was not found")
        raise ValueError(f"Version variable {version_name!r} is not unique")

    if len(assignments) == 1:
        return assignments[0]

    if not assignments:
        raise ValueError("No quoted version variables were found")

    names = ", ".join(match.group("name") for match in assignments)
    raise ValueError(
        "Multiple version variables were found; pass one explicitly: " + names
    )


def render(match: re.Match[str], field: str) -> str:
    if field == "value":
        return match.group("value")
    if field == "name":
        return match.group("name")
    return json.dumps(
        {"name": match.group("name"), "value": match.group("value")},
        sort_keys=True,
    )


def main() -> int:
    args = parse_args()

    try:
        text = args.nix_file.read_text(encoding="utf-8")
        assignment = select_assignment(version_assignments(text), args.version_name)
        print(render(assignment, args.field))
    except OSError as error:
        print(f"Error: {error}", file=sys.stderr)
        return 1
    except ValueError as error:
        print(f"Error: {error}", file=sys.stderr)
        return 2

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
