#!/usr/bin/env bash
set -euo pipefail

usage() {
    echo "Usage: get-latest-github-version <github-owner/repo|github-url>" >&2
}

if [ "$#" -ne 1 ]; then
    usage
    exit 2
fi

script_dir=$(CDPATH='' cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
repo_root=$(CDPATH='' cd -- "$script_dir/.." && pwd)

exec "$repo_root/scripts/github-latest-release.py" "$1"
