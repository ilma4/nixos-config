#!/usr/bin/env bash
set -euo pipefail

usage() {
    cat >&2 <<'EOF'
Usage: update-docker-container [--dry-run|--apply] --version-name <name> [--release-prefix <prefix>] [--docker-build-metadata] <service-nix-file> <github-owner/repo|github-url>

Fetches the current Nix version, latest stable GitHub release, and changelog
for one simple docker-compose service. Dry-run is the default; pass --apply to
write the latest version into the Nix file.
EOF
}

mode=dry-run
version_name=
release_prefix=
docker_build_metadata=false

while [ "$#" -gt 0 ]; do
    case "$1" in
        --dry-run)
            mode=dry-run
            shift
            ;;
        --apply)
            mode=apply
            shift
            ;;
        --version-name)
            if [ "$#" -lt 2 ]; then
                echo "Error: --version-name requires a value" >&2
                exit 2
            fi
            version_name=$2
            shift 2
            ;;
        --release-prefix)
            if [ "$#" -lt 2 ]; then
                echo "Error: --release-prefix requires a value" >&2
                exit 2
            fi
            release_prefix=$2
            shift 2
            ;;
        --docker-build-metadata)
            docker_build_metadata=true
            shift
            ;;
        -h | --help)
            usage
            exit 0
            ;;
        --)
            shift
            break
            ;;
        -*)
            echo "Error: unknown option: $1" >&2
            usage
            exit 2
            ;;
        *)
            break
            ;;
    esac
done

if [ -z "$version_name" ] || [ "$#" -ne 2 ]; then
    usage
    exit 2
fi

service_file=$1
github_repo=$2

script_dir=$(CDPATH='' cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
repo_root=$(CDPATH='' cd -- "$script_dir/.." && pwd)

case "$service_file" in
    /*) service_path=$service_file ;;
    *) service_path=$repo_root/$service_file ;;
esac

if [ ! -f "$service_path" ]; then
    echo "Error: service Nix file does not exist: $service_file" >&2
    exit 1
fi

current_version=$("$script_dir/get-docker-image-version" "$service_path" "$version_name")

current_release_version=$current_version
if [ "$docker_build_metadata" = true ]; then
    if [[ "$current_release_version" =~ ^([0-9]+[.][0-9]+[.][0-9]+)-(.+)$ ]]; then
        current_release_version="${BASH_REMATCH[1]}+${BASH_REMATCH[2]}"
    fi
fi

current_release=$current_release_version
if [ -n "$release_prefix" ]; then
    case "$current_release_version" in
        "$release_prefix"*) current_release=$current_release_version ;;
        *) current_release="${release_prefix}${current_release_version}" ;;
    esac
fi

latest_release=$("$script_dir/get-latest-github-version" "$github_repo")

latest_version=$latest_release
if [ -n "$release_prefix" ]; then
    case "$latest_release" in
        "$release_prefix"*) latest_version=${latest_release#"$release_prefix"} ;;
        *)
            echo "Error: latest release $latest_release does not start with expected prefix $release_prefix" >&2
            exit 1
        ;;
    esac
fi

if [ "$docker_build_metadata" = true ]; then
    latest_version=${latest_version/+/-}
fi

if [[ "$latest_version" == *+* ]]; then
    echo "Error: target Docker image version contains '+': $latest_version" >&2
    echo "If this repo publishes Docker tags with '-' for SemVer build metadata, add --docker-build-metadata." >&2
    exit 1
fi

case "$service_path" in
    "$repo_root"/*) service_ref=${service_path#"$repo_root"/} ;;
    *) service_ref=$service_path ;;
esac

cat <<EOF
Service file: $service_ref
GitHub repo: $github_repo
Version variable: $version_name
Current file version: $current_version
Current GitHub release: $current_release
Latest GitHub release: $latest_release
Target file version: $latest_version
Mode: $mode
EOF

if [ "$current_release" = "$latest_release" ]; then
    echo "Already up to date."
    exit 0
fi

echo
echo "Changelog:"
"$script_dir/get-github-changelog" "$github_repo" "$current_release" "$latest_release"

echo
if [ "$mode" = "apply" ]; then
    "$script_dir/set-docker-image-version" "$service_path" "$latest_version" "$version_name"
else
    "$script_dir/set-docker-image-version" --dry-run "$service_path" "$latest_version" "$version_name"
fi
