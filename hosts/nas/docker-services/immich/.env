# You can find documentation for all the supported env variables at https://immich.app/docs/install/environment-variables

# The location where your uploaded files are stored
UPLOAD_LOCATION=/srv/immich/library

# The location where your database files are stored. Network shares are not supported for the database
DB_DATA_LOCATION=/srv/immich/postgres

# To set a timezone, uncomment the next line and change Etc/UTC to a TZ identifier from this list: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones#List
TZ=Europe/Berlin

# The Immich version is managed by immich-version in immich.nix and injected by systemd.
# Keep IMMICH_VERSION out of this env file to avoid conflicting version sources.

# The postgres password is managed separately via sops and injected at runtime.
# Use create-secrets.sh and rotate-db-password.sh to manage it.

# The values below this line do not need to be changed
###################################################################################
DB_USERNAME=postgres
DB_DATABASE_NAME=immich
